---
import { getCollection } from 'astro:content';
import Base from '@theme/layouts/Base.astro';
import PostCard from '@theme/components/PostCard.astro';
import Sidebar from '@theme/components/Sidebar.astro';

const authorModules = import.meta.glob('../../content/authors/*.json', { eager: true });
const authors = Object.values(authorModules).map((m: any) => m.default || m);

export function getStaticPaths() {
  const mods = import.meta.glob('../../content/authors/*.json', { eager: true });
  const list = Object.values(mods).map((m: any) => m.default || m);
  return list.map((a: any) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const author = authors.find((a: any) => a.slug === slug);
if (!author) return Astro.redirect('/404');

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const authorPosts = allPosts
  .filter(p => p.data.author === author.name)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<Base title={`${author.name} — Author`} description={author.bio}>

  <!-- Author Hero -->
  <header class="author-header">
    <div class="author-avatar">
      {author.avatar
        ? <img src={author.avatar} alt={author.name} />
        : <span class="avatar-placeholder">{author.name.split(' ').map((n: string) => n[0]).join('')}</span>
      }
    </div>
    <h1 class="author-name">{author.name}</h1>
    <span class="author-role">{author.role}</span>
    {author.social?.linkedin && (
      <a class="linkedin-btn" href={author.social.linkedin} target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
    )}
  </header>

  <!-- Author Details -->
  <section class="author-details">
    {author.bio && (
      <div class="author-bio">
        {author.bio.split('\n').map((p: string) => p.trim() && <p>{p}</p>)}
      </div>
    )}

    {author.expertise && (
      <div class="detail-block">
        <h3>Expertise</h3>
        <p>{author.expertise}</p>
      </div>
    )}

    {author.equipment && author.equipment.length > 0 && (
      <div class="detail-block">
        <h3>Equipment</h3>
        <ul>
          {author.equipment.map((item: string) => <li>{item}</li>)}
        </ul>
      </div>
    )}

    {author.education && (
      <div class="detail-block">
        <h3>Education</h3>
        <p>{author.education}</p>
      </div>
    )}
  </section>

  <!-- Author's Articles -->
  <section class="author-articles">
    <h2>Articles by {author.name}</h2>
    {authorPosts.length > 0 ? (
      <div class="articles-layout">
        <div class="articles-grid">
          {authorPosts.map(post => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              heroImage={post.data.heroImage}
              category={post.data.category}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </div>
        <aside class="articles-sidebar">
          <Sidebar />
        </aside>
      </div>
    ) : (
      <p class="no-posts">No articles yet. Check back soon.</p>
    )}
  </section>

</Base>

<style>
  /* ── Author Hero (深色) ── */
  .author-header {
    background: var(--color-dark-bg, #1e2a3a);
    text-align: center;
    padding: 4rem 40px 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }
  .author-avatar {
    width: 128px;
    height: 128px;
    border-radius: 50%;
    border: 4px solid #fff;
    background: rgba(255, 255, 255, .15);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 6px;
  }
  .author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }
  .avatar-placeholder {
    font-size: 2.5rem;
    font-weight: 700;
    color: #fff;
  }
  .author-name {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 800;
    color: #fff;
    letter-spacing: -.03em;
  }
  .author-role {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-cta-yellow, #eab308);
  }
  .linkedin-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    padding: 8px 20px;
    border: 1.5px solid rgba(255, 255, 255, .7);
    border-radius: 6px;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background .15s, border-color .15s;
  }
  .linkedin-btn:hover {
    background: rgba(255, 255, 255, .1);
    border-color: #fff;
  }
  .linkedin-btn svg {
    flex-shrink: 0;
  }

  /* ── Author Details ── */
  .author-details {
    max-width: 800px;
    margin: 3rem auto;
    padding-inline: 40px;
    display: grid;
    gap: 2rem;
  }
  .detail-block h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text, #1e293b);
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-border, #e2e8f0);
  }
  .author-bio p,
  .detail-block p {
    font-size: 15px;
    color: var(--color-text-muted, #64748b);
    line-height: 1.7;
    margin-bottom: 8px;
  }
  .author-bio p:last-child,
  .detail-block p:last-child {
    margin-bottom: 0;
  }
  .detail-block ul {
    list-style: none;
    padding: 0;
  }
  .detail-block li {
    position: relative;
    padding-left: 18px;
    font-size: 15px;
    color: var(--color-text-muted, #64748b);
    line-height: 1.7;
    margin-bottom: 4px;
  }
  .detail-block li::before {
    content: "";
    position: absolute;
    left: 0;
    top: .6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary, #2563eb);
  }

  /* ── Articles Section ── */
  .author-articles {
    padding-bottom: 2rem;
  }
  .author-articles > h2 {
    max-width: var(--max-width, 1120px);
    margin: 0 auto 1.5rem;
    padding-inline: 40px;
    font-size: 24px;
    font-weight: 700;
    color: var(--color-text, #1e293b);
    letter-spacing: -.02em;
  }
  .articles-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    max-width: var(--max-width, 1120px);
    margin-inline: auto;
    padding-inline: 40px;
    align-items: start;
  }
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .articles-sidebar {
    position: sticky;
    top: 80px;
    align-self: start;
  }
  .no-posts {
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .articles-layout {
      grid-template-columns: 1fr;
      padding-inline: 20px;
    }
    .articles-sidebar {
      display: none;
    }
  }
  @media (max-width: 768px) {
    .author-header {
      padding: 3rem 20px 2rem;
    }
    .author-details {
      padding-inline: 20px;
      margin: 2rem auto;
    }
    .author-articles > h2 {
      padding-inline: 20px;
    }
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
