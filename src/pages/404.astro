---
import Base from '@theme/layouts/Base.astro';
---

<Base title="404 - Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="not-found container">
    <h1>404</h1>
    <p>The page you're looking for doesn't exist.</p>
    <a href="/" class="btn btn-primary">← Back to Home</a>
  </div>
</Base>

<style>
  .not-found { text-align: center; padding: 6rem 0; }
  .not-found h1 { font-size: 6rem; color: var(--color-border); margin-bottom: 1rem; }
  .not-found p { font-size: 1.25rem; color: var(--color-text-muted); margin-bottom: 2rem; }
</style>
