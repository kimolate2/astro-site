---
import { getCollection } from 'astro:content';
import Base from '@theme/layouts/Base.astro';
import PostCard from '@theme/components/PostCard.astro';
import Sidebar from '@theme/components/Sidebar.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const categories = [...new Set(allPosts.map(p => p.data.category).filter(Boolean))];

const postsPerPage = 12;
const totalPages = Math.ceil(posts.length / postsPerPage);
const currentPage = 1;
const paginatedPosts = posts.slice(0, postsPerPage);
---

<Base title="Blog" description="All articles and reviews.">

  <section class="page-hero">
    <h1>All Articles</h1>
    <p>Browse our latest reviews, guides, and tutorials.</p>
  </section>

  <div class="filter-bar">
    <a class="filter-chip active" href="/blog">All</a>
    {categories.map(cat => (
      <a class="filter-chip" href={`/category/${cat!.toLowerCase()}`}>{cat}</a>
    ))}
  </div>

  <div class="two-col">
    <main class="post-grid">
      {paginatedPosts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
          category={post.data.category}
          tags={post.data.tags}
          slug={post.id}
          author={post.data.author}
        />
      ))}
    </main>

    <aside class="sidebar-col">
      <Sidebar />
    </aside>
  </div>

  {totalPages > 1 && (
    <nav class="blog-pagination" aria-label="Pagination">
      <span class="page-info">Page {currentPage} of {totalPages}</span>
      <div class="page-buttons">
        <a class:list={["page-btn", { disabled: currentPage <= 1 }]} href={currentPage > 1 ? `/blog/${currentPage - 1}` : undefined} aria-disabled={currentPage <= 1 ? "true" : undefined}>Previous</a>
        <a class:list={["page-btn", { disabled: currentPage >= totalPages }]} href={currentPage < totalPages ? `/blog/${currentPage + 1}` : undefined} aria-disabled={currentPage >= totalPages ? "true" : undefined}>Next</a>
      </div>
    </nav>
  )}

</Base>

<style>
  /* ===== Page Hero - shared.css page-hero ===== */
  .page-hero {
    background: var(--color-dark-bg);
    color: #fff;
    text-align: center;
    padding: 4rem 40px 3rem;
  }
  .page-hero h1 {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 8px;
  }
  .page-hero p {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.6);
    max-width: 600px;
    margin: 0 auto;
  }

  /* ===== Filter Bar - blog-list-page.css ===== */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 1.5rem 0;
    margin-top: 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
    max-width: 1120px;
    margin-inline: auto;
    padding-inline: 40px;
  }
  .filter-chip {
    display: inline-block;
    padding: 6px 16px;
    font-size: 14px;
    font-weight: 500;
    border-radius: 50px;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: #fff;
    text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .filter-chip:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-decoration: none;
  }
  .filter-chip.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  /* ===== Two-Column Layout - shared.css two-col ===== */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    max-width: 1120px;
    margin-inline: auto;
    padding-inline: 40px;
  }

  /* ===== Post Grid - blog-list-page.css ===== */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  /* ===== Pagination prev/next - blog-list-page.css ===== */
  .blog-pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 2rem;
    padding-bottom: 2rem;
    margin-top: 2rem;
    border-top: 1px solid var(--color-border);
    max-width: 1120px;
    margin-inline: auto;
    padding-inline: 40px;
  }
  .page-info {
    font-size: 14px;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .page-buttons {
    display: flex;
    gap: 8px;
  }
  .page-btn {
    display: inline-block;
    padding: 8px 18px;
    font-size: 14px;
    font-weight: 500;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: #fff;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .page-btn:hover:not(.disabled) {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-decoration: none;
  }
  .page-btn.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .two-col {
      grid-template-columns: 1fr;
      padding-inline: 20px;
    }
    .sidebar-col {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 3rem 20px 2rem;
    }
    .filter-bar {
      padding-inline: 20px;
    }
    .post-grid {
      grid-template-columns: 1fr;
    }
    .blog-pagination {
      flex-direction: column;
      gap: 12px;
      align-items: center;
      padding-inline: 20px;
    }
  }
</style>
