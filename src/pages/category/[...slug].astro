---
import { getCollection } from 'astro:content';
import Base from '@theme/layouts/Base.astro';
import PostCard from '@theme/components/PostCard.astro';
import Sidebar from '@theme/components/Sidebar.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))];
  return categories.map(category => ({
    params: { slug: category!.toLowerCase() },
    props: { category, posts: posts.filter(p => p.data.category === category) },
  }));
}

const { category, posts } = Astro.props;
const sortedPosts = posts.sort((a: any, b: any) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const categoryDescriptions: Record<string, string> = {
  'Tech': 'Explore our comprehensive guides and reviews on the latest technology and data recovery tools.',
  'Life': 'Practical tips and advice for everyday digital life and data management.',
  'Business': 'Enterprise-level data recovery solutions and business continuity guides.',
  'Tutorial': 'Step-by-step tutorials for recovering lost data across various platforms and devices.',
};
const desc = categoryDescriptions[category] || `Browse all articles in the ${category} category.`;

const postsPerPage = 12;
const totalPages = Math.ceil(sortedPosts.length / postsPerPage);
const currentPage = 1;
const displayPosts = sortedPosts.slice(0, postsPerPage);

function getPageNumbers(current: number, total: number): (number | string)[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | string)[] = [1];
  if (current > 3) pages.push('...');
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push('...');
  pages.push(total);
  return pages;
}
const pageNumbers = getPageNumbers(currentPage, totalPages);
const baseUrl = `/category/${category!.toLowerCase()}`;
---

<Base title={`${category} - Articles`} description={desc}>
  <section class="page-hero">
    <h1>{category}</h1>
  </section>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li><span aria-current="page">{category}</span></li>
    </ol>
  </nav>

  <div class="category-description">
    <p>{desc}</p>
  </div>

  <div class="two-col">
    <main class="category-grid">
      {displayPosts.map((post: any) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          heroImage={post.data.heroImage}
          category={post.data.category}
          tags={post.data.tags}
          slug={post.id}
          author={post.data.author}
        />
      ))}
    </main>
    <aside class="sidebar-col">
      <Sidebar />
    </aside>
  </div>

  {totalPages > 1 && (
    <nav class="cat-pagination" aria-label="Pagination">
      <a
        href={currentPage > 1 ? `${baseUrl}?page=${currentPage - 1}` : '#'}
        class:list={['page-nav-btn', { disabled: currentPage <= 1 }]}
        aria-disabled={currentPage <= 1 ? 'true' : 'false'}
      >Previous</a>
      <ol class="page-numbers">
        {pageNumbers.map((item) => (
          <li>
            {item === '...' ? (
              <span class="ellipsis">&hellip;</span>
            ) : (
              <a
                href={`${baseUrl}?page=${item}`}
                class:list={[{ active: item === currentPage }]}
              >{item}</a>
            )}
          </li>
        ))}
      </ol>
      <a
        href={currentPage < totalPages ? `${baseUrl}?page=${currentPage + 1}` : '#'}
        class:list={['page-nav-btn', { disabled: currentPage >= totalPages }]}
        aria-disabled={currentPage >= totalPages ? 'true' : 'false'}
      >Next</a>
    </nav>
  )}
</Base>

<style>
  /* ===== Page Hero - shared.css page-hero ===== */
  .page-hero {
    background: var(--color-dark-bg);
    color: #fff;
    text-align: center;
    padding: 4rem 40px 3rem;
  }
  .page-hero h1 {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 8px;
  }

  /* ===== Breadcrumb - category-page.css ===== */
  .breadcrumb {
    max-width: 1120px;
    margin-inline: auto;
    padding: 16px 40px 0;
  }
  .breadcrumb ol {
    display: flex;
    align-items: center;
    gap: 6px;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 13px;
    color: var(--color-text-muted);
  }
  .breadcrumb li + li::before {
    content: "\203A";
    margin-right: 6px;
    color: var(--color-text-muted);
  }
  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: var(--color-primary);
  }
  .breadcrumb [aria-current="page"] {
    color: var(--color-text);
    font-weight: 600;
  }

  /* ===== Category Description - category-page.css ===== */
  .category-description {
    padding-block: 20px 28px;
    max-width: 1120px;
    margin-inline: auto;
    padding-inline: 40px;
  }
  .category-description p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 760px;
    margin: 0;
  }

  /* ===== Two-Column Layout - shared.css two-col ===== */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    max-width: 1120px;
    margin-inline: auto;
    padding-inline: 40px;
  }

  /* ===== Post Grid - category-page.css ===== */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  /* ===== Pagination numbered - category-page.css ===== */
  .cat-pagination {
    max-width: 1120px;
    margin-inline: auto;
    padding: 2.5rem 40px 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .page-numbers {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cat-pagination a,
  .cat-pagination .ellipsis {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 10px;
    font-size: 14px;
    font-weight: 500;
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.12s, color 0.12s;
  }
  .cat-pagination a:hover {
    background: var(--color-bg-alt);
    color: var(--color-primary);
    text-decoration: none;
  }
  .cat-pagination a.active {
    background: var(--color-primary);
    color: #fff;
    font-weight: 700;
  }
  .cat-pagination a[aria-disabled="true"] {
    color: var(--color-text-muted);
    pointer-events: none;
    opacity: 0.45;
  }
  .cat-pagination .ellipsis {
    color: var(--color-text-muted);
    pointer-events: none;
  }
  .page-nav-btn {
    font-weight: 600;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .two-col {
      grid-template-columns: 1fr;
      padding-inline: 20px;
    }
    .sidebar-col {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 3rem 20px 2rem;
    }
    .breadcrumb {
      padding-inline: 20px;
    }
    .category-description {
      padding-inline: 20px;
    }
    .cat-pagination {
      padding-inline: 20px;
    }
  }

  @media (max-width: 640px) {
    .category-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
