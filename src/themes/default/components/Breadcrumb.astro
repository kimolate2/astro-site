---
interface Props {
  items: { label: string; url?: string }[];
}

const { items } = Astro.props;
---

<nav style="font-size: 0.85rem; margin-bottom: 1rem;">
  {items.map((item, i) => (
    <span>
      {item.url ? <a href={item.url}>{item.label}</a> : <span>{item.label}</span>}
      {i < items.length - 1 && <span> / </span>}
    </span>
  ))}
</nav>
