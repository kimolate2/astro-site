---
import { LEARN_BRAND } from '../consts';

const pathname = Astro.url.pathname;

function norm(p: string) {
	return p.replace(/\/$/, '') || '/';
}

const cur = norm(pathname);

function isActive(href: string) {
	const h = norm(href);
	if (h === '/') {
		return cur === '/';
	}
	return cur === h || cur.startsWith(`${h}/`);
}
---

<header class="l-header">
	<div class="l-container l-header__inner">
		<a class="l-brand" href="/">
			<img src="https://learn.gthememarket.com/content/images/2025/08/logo.svg" alt={LEARN_BRAND} width="120" height="40" />
			<span>{LEARN_BRAND}</span>
		</a>
		<nav class="l-nav" aria-label="主导航">
			<a href="/" aria-current={isActive('/') ? 'page' : undefined}>首页</a>
			<a href="/blog/" aria-current={isActive('/blog/') ? 'page' : undefined}>博客</a>
			<a
				href="/course/entrepreneurship-and-innovation/"
				aria-current={isActive('/course/entrepreneurship-and-innovation/') ? 'page' : undefined}>示例课程</a>
			<a href="/#latest-courses">课程</a>
		</nav>
	</div>
</header>
