---
import { LEARN_BRAND } from '../consts';

const pathname = Astro.url.pathname;

function norm(p: string) {
	return p.replace(/\/$/, '') || '/';
}

const cur = norm(pathname);

function isActive(href: string) {
	const h = norm(href);
	if (h === '/') {
		return cur === '/';
	}
	return cur === h || cur.startsWith(`${h}/`);
}
---

<header class="l-header">
	<div class="l-container l-header__inner">
		<a class="l-brand" href="/">
			<img src="https://learn.gthememarket.com/content/images/2025/08/logo.svg" alt={LEARN_BRAND} width="120" height="40" />
			<span>{LEARN_BRAND}</span>
		</a>
		<nav class="l-nav" aria-label="Primary">
			<a href="/" aria-current={isActive('/') ? 'page' : undefined}>Home</a>
			<a href="https://learn.gthememarket.com/courses/" target="_blank" rel="noopener noreferrer">Courses</a>
			<a href="/blog/" aria-current={isActive('/blog/') ? 'page' : undefined}>Blog</a>
			<a
				href="/course/entrepreneurship-and-innovation/"
				aria-current={isActive('/course/entrepreneurship-and-innovation/') ? 'page' : undefined}
				>Sample course</a>
			<a href="https://learn.gthememarket.com/contact-us/" target="_blank" rel="noopener noreferrer">Contact Us</a>
		</nav>
	</div>
</header>
