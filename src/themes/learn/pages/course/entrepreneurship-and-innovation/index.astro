---
import BaseHead from '@theme/components/BaseHead.astro';
import Footer from '@theme/components/Footer.astro';
import Header from '@theme/components/Header.astro';
import CourseSamplePage from '@theme/components/CourseSamplePage.astro';
import { LEARN_BRAND, LEARN_INDEX_META_DESCRIPTION } from '@theme/consts';

const title = `${LEARN_BRAND} · Entrepreneurship & Innovation`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={LEARN_INDEX_META_DESCRIPTION} />
	</head>
	<body data-theme="learn">
		<Header />
		<main>
			<CourseSamplePage />
		</main>
		<Footer />
	</body>
</html>
